FROM postgres:17

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       postgresql-17-pgvector \
    && rm -rf /var/lib/apt/lists/*

ENV POSTGRES_USER=klaus \
    POSTGRES_PASSWORD=klaus \
    POSTGRES_DB=klaus

COPY scripts/init-pgvector.sql /docker-entrypoint-initdb.d/

EXPOSE 5432
