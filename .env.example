# klaus environment variables — API keys and secrets
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection (default works with podman-compose setup)
DATABASE_URL=postgresql://klaus:klaus@localhost:5432/klaus

# ── Model Backend API Keys ────────────────────────────────
# Google Gemini
GOOGLE_API_KEY=

# HuggingFace — for HF Inference API + image generation
HF_TOKEN=

# OpenAI (future)
# OPENAI_API_KEY=

# Anthropic (future)
# ANTHROPIC_API_KEY=

# ── Observability ─────────────────────────────────────────
# Langfuse (optional — tracing and cost tracking)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
