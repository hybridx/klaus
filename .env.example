# klaus environment variables — API keys and secrets
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Model Backend API Keys ────────────────────────────────
# Google Gemini
GOOGLE_API_KEY=

# OpenAI (future)
# OPENAI_API_KEY=

# Anthropic (future)
# ANTHROPIC_API_KEY=

# ── Observability ─────────────────────────────────────────
# Langfuse (optional — tracing and cost tracking)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
